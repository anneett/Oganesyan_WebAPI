  "components": {
    "schemas": {
      "DatabaseDeployDto": {
        "type": "object",
        "properties": {
          "dbMetaId": {
            "type": "integer",
            "format": "int32"
          },
          "physicalDatabaseName": {
            "type": "string",
            "nullable": true
          },
          "executeScript": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "DatabaseDeployment": {
        "required": [
          "databaseMetaId",
          "dbMetaId",
          "physicaDatabaseName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "databaseMetaId": {
            "type": "integer",
            "format": "int32"
          },
          "databaseMeta": {
            "$ref": "#/components/schemas/DatabaseMeta"
          },
          "dbMetaId": {
            "type": "integer",
            "format": "int32"
          },
          "dbMeta": {
            "$ref": "#/components/schemas/DbMeta"
          },
          "physicaDatabaseName": {
            "minLength": 1,
            "type": "string"
          },
          "isDeployed": {
            "type": "boolean"
          },
          "deployedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "DatabaseMeta": {
        "required": [
          "description",
          "logicalName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "logicalName": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "erdImagePath": {
            "type": "string",
